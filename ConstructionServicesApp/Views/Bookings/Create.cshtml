@model ConstructionServicesApp.Models.ViewModels.BookingViewModel

@{
    ViewData["Title"] = "Create Booking";
}

<h1>Create Booking</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Client</label>
        <select asp-for="ClientID" class="form-control">
            <option value="">-- Select Client --</option>
            @foreach (var c in ViewBag.Clients)
            {
                <option value="@c.ClientID">@c.FullName</option>
            }
        </select>
        <span asp-validation-for="ClientID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Date</label>
        <input asp-for="BookingDate" type="date" class="form-control" />
        <span asp-validation-for="BookingDate" class="text-danger"></span>
    </div>

    <h4>Services</h4>
    <button type="button" class="btn btn-primary mb-2" onclick="addRow()">Add Service</button>

    <table class="table" id="serviceTable">
        <thead>
            <tr>
                <th>Service</th>
                <th>Hours</th>
                <th>Rate</th>
                <th>Amount</th>
                <th></th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <div class="mb-3">
        <label>Total Amount</label>
        <input asp-for="TotalAmount" id="TotalAmount" class="form-control" readonly />
    </div>

    <button type="submit" class="btn btn-success">Save Booking</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Properly serialize services from ViewBag to JS
        let services = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Services ?? new List<object>()));
        if (!Array.isArray(services)) services = [];

        function addRow() {
            let index = document.querySelectorAll("#serviceTable tbody tr").length;

            let row = `
            <tr>
                <td>
                    <select name="Services[${index}].ServiceID" class="form-control" onchange="setRate(this, ${index})">
                        <option value="">-- Select Service --</option>
                        ${services.map(s => `<option value="${s.ServiceID}" data-rate="${s.HourlyRate}">${s.ServiceName}</option>`).join("")}
                    </select>
                </td>
                <td>
                    <input type="number" name="Services[${index}].Hours" class="form-control" onchange="compute(${index})" min="0" />
                </td>
                <td>
                    <input type="text" name="Services[${index}].Rate" class="form-control" readonly />
                </td>
                <td>
                    <input type="text" name="Services[${index}].Amount" class="form-control" readonly />
                </td>
                <td>
                    <button type="button" class="btn btn-danger" onclick="removeRow(this)">X</button>
                </td>
            </tr>`;

            document.querySelector("#serviceTable tbody").insertAdjacentHTML("beforeend", row);
        }

        function setRate(select, index) {
            let rate = select.options[select.selectedIndex].getAttribute("data-rate") || 0;
            document.getElementsByName(`Services[${index}].Rate`)[0].value = rate;
            compute(index);
        }

        function compute(index) {
            let hours = parseFloat(document.getElementsByName(`Services[${index}].Hours`)[0].value) || 0;
            let rate = parseFloat(document.getElementsByName(`Services[${index}].Rate`)[0].value) || 0;
            let amount = hours * rate;
            document.getElementsByName(`Services[${index}].Amount`)[0].value = amount.toFixed(2);
            computeTotal();
        }

        function computeTotal() {
            let total = 0;
            document.querySelectorAll("[name$='.Amount']").forEach(el => {
                total += parseFloat(el.value) || 0;
            });
            document.getElementById("TotalAmount").value = total.toFixed(2);
        }

        function removeRow(btn) {
            btn.closest("tr").remove();
            computeTotal();
        }
    </script>
}