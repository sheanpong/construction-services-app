@model IEnumerable<ConstructionServicesApp.Models.Payment>

@{
    ViewData["Title"] = "Payments";
}

<h1>Payments</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Payment</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Client</th>
            <th>Amount Paid</th>
            <th>Payment Date</th>
            <th>Method</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Billing?.Booking?.Client?.FullName</td>
                    <td>₱ @item.AmountPaid</td>
                    <td>@item.PaymentDate.ToShortDateString()</td>
                    <td>@item.PaymentMethod</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.PaymentID" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.PaymentID" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.PaymentID" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No payments found</td>
            </tr>
        }
    </tbody>
</table>