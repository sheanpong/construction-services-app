@model ConstructionServicesApp.Models.Payment

@{
    ViewData["Title"] = "Edit Payment";
}

<h2>Edit Payment</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="PaymentID" />

    <div class="form-group mb-3">
        <label>Billing</label>
        <select asp-for="BillingID" class="form-control" asp-items="ViewBag.BillingID"></select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="AmountPaid"></label>
        <input asp-for="AmountPaid" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="PaymentDate"></label>
        <input asp-for="PaymentDate" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="PaymentMethod"></label>
        <input asp-for="PaymentMethod" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>